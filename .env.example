# SMTP voor het offerteformulier (/api/offerte) — Hostinger mailbox.
# Zet deze als environment variables in Coolify. Zonder SMTP_USER/SMTP_PASS
# verstuurt het formulier niets in productie (en logt het alleen lokaal).

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@studiomicrobeton.nl
SMTP_PASS=                       # wachtwoord van de mailbox info@studiomicrobeton.nl

# Optioneel — defaulten naar SMTP_USER als ze leeg zijn:
# OFFERTE_TO=info@studiomicrobeton.nl     # waar de aanvragen heen gaan
# OFFERTE_FROM=info@studiomicrobeton.nl   # afzender van de mail
